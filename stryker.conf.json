{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Mutation testing focused on pure business logic. Components are excluded because DOM/D3 mutants are noisy and slow.",
  "packageManager": "yarn",
  "reporters": ["html", "clear-text", "progress"],
  "testRunner": "vitest",
  "vitest": { "configFile": "vitest.config.ts" },
  "coverageAnalysis": "perTest",
  "mutate": [
    "store/**/*.ts",
    "hooks/**/*.ts",
    "utils/**/*.ts",
    "services/**/*.ts",
    "!**/*.test.{ts,tsx}",
    "!**/*.spec.{ts,tsx}",
    "!**/__tests__/**",
    "!**/index.ts"
  ],
  "thresholds": { "high": 85, "low": 75, "break": 75 },
  "timeoutMS": 30000,
  "concurrency": 2,
  "htmlReporter": { "fileName": "reports/mutation/index.html" }
}
