# ============================================
# EPIModel Next - Environment Variables
# ============================================
# 
# Copy this file to .env.local and update the values
# for your local development environment.
#
# Usage:
#   cp .env.example .env.local
#   # Then edit .env.local with your values (optional)
#
# NOTE: API_URL is automatically determined based on NODE_ENV
# - Development: http://localhost:3001
# - Production: http://epymodel.uaa.edu.py:3001
# - You can override it by setting NEXT_PUBLIC_API_URL
#
# ============================================

# --------------------------------------------
# API Configuration (Optional)
# --------------------------------------------

# API URL - Automatically determined by NODE_ENV
# Uncomment and set only if you need to override the default behavior
# Development default: http://localhost:3001
# Production default: http://epymodel.uaa.edu.py:3001
# NEXT_PUBLIC_API_URL=http://localhost:3001

# Timeout de requests API en milisegundos (default: 30000)
NEXT_PUBLIC_API_TIMEOUT=30000

# NÃºmero de intentos de retry para requests fallidos (default: 3)
NEXT_PUBLIC_API_RETRY_ATTEMPTS=3

# --------------------------------------------
# Environment
# --------------------------------------------

# Modo de ejecuciÃ³n: development, production, test
# Next.js automatically sets this based on the command:
# - yarn dev -> development
# - yarn build && yarn start -> production
# You can override if needed, but it's not recommended
# NODE_ENV=development

# --------------------------------------------
# Feature Flags
# --------------------------------------------

# Habilitar logs de debug (true/false)
# Set to 'true' to enable detailed debug logging
NEXT_PUBLIC_DEBUG_LOGS=false

# Habilitar reporte de errores (true/false)
# Set to 'true' to enable error reporting
NEXT_PUBLIC_ERROR_REPORTING=false

# --------------------------------------------
# Revalidation (Optional)
# --------------------------------------------

# Token para revalidaciÃ³n de pÃ¡ginas estÃ¡ticas
# Used for on-demand revalidation via API routes
# REVALIDATE_TOKEN=your-secret-token-here

# --------------------------------------------
# Notes
# --------------------------------------------
#
# 1. API_URL is automatically determined based on NODE_ENV:
#    - Development: http://localhost:3001
#    - Production: http://epymodel.uaa.edu.py:3001
#    - You can override with NEXT_PUBLIC_API_URL if needed
#
# 2. Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# 3. Never commit .env.local to version control
# 4. Always use .env.example as a template
# 5. For production, set NODE_ENV=production (usually automatic)
#
